generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  departments Department[]
  periods     Period[]
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  username       String?          @unique // Login with username (e.g. momen.zaki)
  name           String
  image          String?          // Profile photo URL
  passwordHash   String
  role           String           // SUPER_ADMIN | FUNCTION_HEAD | STRATEGY_MANAGER | EXECUTIVE
  departmentId   String?          // Legacy — kept for backward compat
  department     Department?      @relation(fields: [departmentId], references: [id])
  organizationId String?          // Null for SUPER_ADMIN (platform-level user)
  organization   Organization?    @relation(fields: [organizationId], references: [id])
  assignments    UserDepartment[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model UserDepartment {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  permission   String     @default("EDIT") // EDIT | VIEW_ONLY
  createdAt    DateTime   @default(now())

  @@unique([userId, departmentId])
}

model Department {
  id             String           @id @default(cuid())
  slug           String
  name           String
  headName       String
  initials       String
  sortOrder      Int              @default(0)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  users          User[]
  assignments    UserDepartment[]
  objectives     Objective[]
  keyActions     KeyAction[]
  submissions    Submission[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, slug])
}

model Objective {
  id              String           @id @default(cuid())
  code            String
  statement       String
  unit            String
  targetDirection String           @default(">=") // >, <, <=, >=, =
  targetPeriod    String           @default("MONTHLY") // MONTHLY | QUARTERLY | HALF_ANNUAL | ANNUAL
  trackingPeriod  String           @default("MONTHLY") // MONTHLY | QUARTERLY | HALF_ANNUAL | ANNUAL
  monthlyBaseline String           @default("[]") // JSON: array of 12 numbers
  monthlyTarget   String           @default("[]") // JSON: array of 12 numbers
  sortOrder       Int              @default(0)
  departmentId    String
  department      Department       @relation(fields: [departmentId], references: [id])
  entries         ObjectiveEntry[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([departmentId, code])
}

model KeyAction {
  id          String           @id @default(cuid())
  code        String
  description String
  dueDate     DateTime
  owner       String
  frequency   String           @default("MONTHLY") // MONTHLY | QUARTERLY
  sortOrder   Int              @default(0)
  departmentId String
  department   Department       @relation(fields: [departmentId], references: [id])
  entries      KeyActionEntry[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Period {
  id             String       @id @default(cuid())
  label          String
  year           Int
  month          Int
  deadline       DateTime
  isActive       Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  submissions    Submission[]
  createdAt      DateTime     @default(now())

  @@unique([organizationId, year, month])
}

model Submission {
  id               String           @id @default(cuid())
  status           String           @default("DRAFT")
  submittedAt      DateTime?
  departmentId     String
  department       Department       @relation(fields: [departmentId], references: [id])
  periodId         String
  period           Period           @relation(fields: [periodId], references: [id])
  objectiveEntries ObjectiveEntry[]
  actionEntries    KeyActionEntry[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([departmentId, periodId])
}

model ObjectiveEntry {
  id            String     @id @default(cuid())
  achievedValue String     @default("")
  note          String     @default("")
  submissionId  String
  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  objectiveId   String
  objective     Objective  @relation(fields: [objectiveId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([submissionId, objectiveId])
}

model KeyActionEntry {
  id           String     @id @default(cuid())
  status       String     @default("NOT_STARTED")
  progress     String     @default("")
  nextPriority String     @default("")
  blockers     String     @default("")
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  keyActionId  String
  keyAction    KeyAction  @relation(fields: [keyActionId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([submissionId, keyActionId])
}
